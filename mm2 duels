getgenv().RAYFIELD_ASSET_ID = 110785486010149
local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local UserInputService = game:GetService("UserInputService")
local LocalPlayer = Players.LocalPlayer

local isToggledOn = false

local Window = Rayfield:CreateWindow({
	Name = "Match Debug Panel",
	LoadingTitle = "Match Debug",
	LoadingSubtitle = "Admin Tools",
	ConfigurationSaving = {
		Enabled = false,
	},
	KeySystem = false,
})

local Tab = Window:CreateTab("Main", "code")

Tab:CreateToggle({
    Name = "Kill Farm",
    CurrentValue = isToggledOn,
	Callback = function(Value)
        if Value then
            isToggledOn = true
        else
            isToggledOn = false
        end
	end,
})

local Keybind = Tab:CreateKeybind({
   Name = "Keybind Example",
   CurrentKeybind = "Q",
   HoldToInteract = false,
   Flag = "Keybind1",
   Callback = function(Keybind)
        isToggledOn = not isToggledOn
   end,
})

while true do
    if isToggledOn then
        local myChar = LocalPlayer.Character
        local remotes = ReplicatedStorage:FindFirstChild("Remotes")
        
        if myChar and myChar:FindFirstChild("HumanoidRootPart") and remotes then
            local stabRemote = remotes:FindFirstChild("Stab")
            local gunRemote = remotes:FindFirstChild("ShootGun")
            
            for _, player in ipairs(Players:GetPlayers()) do
                if player ~= LocalPlayer and player.Character then
                    
                    if stabRemote then
                        local targetArm = player.Character:FindFirstChild("LeftUpperArm")
                        if targetArm then stabRemote:FireServer(targetArm) end
                    end
                    
                    if gunRemote then
                        local targetRoot = player.Character:FindFirstChild("HumanoidRootPart")
                        if targetRoot then
                            local ohVector31 = myChar.HumanoidRootPart.Position
                            local ohVector32 = targetRoot.Position
                            local ohInstance3 = targetRoot
                            local ohVector34 = (ohVector32 - ohVector31).Unit
                            
                            gunRemote:FireServer(ohVector31, ohVector32, ohInstance3, ohVector34)
                        end
                    end
                    
                end
            end
        end
    end
    
    task.wait(1) 
end