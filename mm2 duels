local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local UserInputService = game:GetService("UserInputService")
local LocalPlayer = Players.LocalPlayer

local isToggledOn = false

UserInputService.InputBegan:Connect(function(input, gameProcessedEvent)
    if gameProcessedEvent then return end
    
    if input.KeyCode == Enum.KeyCode.Q then
        isToggledOn = not isToggledOn
    end
end)

while true do
    if isToggledOn then
        local myChar = LocalPlayer.Character
        local remotes = ReplicatedStorage:FindFirstChild("Remotes")
        
        if myChar and myChar:FindFirstChild("HumanoidRootPart") and remotes then
            local stabRemote = remotes:FindFirstChild("Stab")
            local gunRemote = remotes:FindFirstChild("ShootGun")
            
            for _, player in ipairs(Players:GetPlayers()) do
                if player ~= LocalPlayer and player.Character then
                    
                    if stabRemote then
                        local targetArm = player.Character:FindFirstChild("LeftUpperArm")
                        if targetArm then stabRemote:FireServer(targetArm) end
                    end
                    
                    if gunRemote then
                        local targetRoot = player.Character:FindFirstChild("HumanoidRootPart")
                        if targetRoot then
                            local ohVector31 = myChar.HumanoidRootPart.Position
                            local ohVector32 = targetRoot.Position
                            local ohInstance3 = targetRoot
                            local ohVector34 = (ohVector32 - ohVector31).Unit
                            
                            gunRemote:FireServer(ohVector31, ohVector32, ohInstance3, ohVector34)
                        end
                    end
                    
                end
            end
        end
    end
    
    task.wait(1) 
end