local function getEquippedLauncher()
    local character = LocalPlayer.Character
    if character and character:FindFirstChild("Launcher") then
        return character.Launcher
    end
    return LocalPlayer.Backpack:FindFirstChild("Launcher")
end

BoostButton.MouseButton1Click:Connect(function()
    StatusLabel.Text = "STATUS: PACKING BOOST STRINGS..."
    BoostRemote:FireServer("CoinBoost", 180, 2)
    task.wait(0.2)
    StatusLabel.Text = "STATUS: COIN BOOST COMPLETED"
end)

ExplodeButton.MouseButton1Click:Connect(function()
    StatusLabel.Text = "STATUS: SCANNING EQUIPMENT PIPES..."
    
    local launcher = getEquippedLauncher()
    if not launcher then 
        StatusLabel.Text = "STATUS: CRITICAL ERROR - NO LAUNCHER"
        return 
    end
    
    local launcherStats = launcher:FindFirstChild("Stats")
    local rocketBoom = launcher:FindFirstChild("Assets") 
        and launcher.Assets:FindFirstChild("Rocket") 
        and launcher.Assets.Rocket:FindFirstChild("Boom")
        
    if not launcherStats or not rocketBoom then 
        StatusLabel.Text = "STATUS: ASSET STRUCTURE MISSING"
        return 
    end
    
    local chosenArea = TargetAreaInput.Text
    local areasFolder = workspace:FindFirstChild("Areas")
    local targetFolder = areasFolder and areasFolder:FindFirstChild(chosenArea)
    
    if not targetFolder then
        StatusLabel.Text = "STATUS: TARGET METRIC DIRECTORY NOT FOUND"
        return
    end
    
    -- Syncs target input directory directly with the server zone validation pipeline
    StatusLabel.Text = "STATUS: SYNCHRONIZING AREA CONTEXT..."
    AreaRemote:FireServer(chosenArea)
    task.wait(0.1) -- Yields briefly to allow server verification to pass
    
    StatusLabel.Text = "STATUS: RESOLVING BLAST MATH DISTANCES..."
    local explosionPositions = {}
    local rocketsFired = 0
    
    for _, item in ipairs(targetFolder:GetDescendants()) do
        if item:IsA("BasePart") then
            local pos = item.Position
            local alreadyCovered = false
            
            for _, existingPos in ipairs(explosionPositions) do
                if (pos - existingPos).Magnitude < explosionRadius then
                    alreadyCovered = true
                    break
                end
            end
            
            if not alreadyCovered then
                table.insert(explosionPositions, pos)
                rocketsFired = rocketsFired + 1
                
                ExplodeRemote:FireServer(rocketAttackID, launcherStats, pos, rocketBoom)
                
                if rocketsFired % 5 == 0 then
                    task.wait(0.01)
                end
            end
        end
    end
    
    StatusLabel.Text = "STATUS: RECOVERING... SELLING IN 10 SECONDS"
    
    task.spawn(function()
        for count = 9, 1, -1 do
            task.wait(1)
            StatusLabel.Text = "STATUS: CLEARING FIELD... SELLING IN " .. count .. "s"
        end
        task.wait(1)
        
        StatusLabel.Text = "STATUS: DISPATCHING COLLECTION CALL..."
        SellRemote:FireServer()
        task.wait(0.5)-- Automatically signs character state back to NoZone fallback profile after sell routine
        AreaRemote:FireServer("NoZone")
        StatusLabel.Text = "STATUS: COMPLETE CYCLED SEQUENCING"
    end)
end)

UserInputService.InputBegan:Connect(function(input, gameProcessedEvent)
    if gameProcessedEvent then return end
    if input.KeyCode == Enum.KeyCode.RightShift then
        ScreenGui.Enabled = not ScreenGui.Enabled
    end
end)