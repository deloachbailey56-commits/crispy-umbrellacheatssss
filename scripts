local states = { Click = false, Hatch = false }
local cooldowns = { Click = 0.1, Hatch = 0.7 }
local isUnlocked = false
local copyActive = false

local function tweenColor(object, targetColor)
	local info = TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
	TweenService:Create(object, info, {BackgroundColor3 = targetColor}):Play()
end

local function startClickLoop()
	while states.Click and isUnlocked do
		ClickEvent:FireServer()
		task.wait(cooldowns.Click)
	end
end

local function startHatchLoop()
	while states.Hatch and isUnlocked do
		local currentEgg = EggTextBox.Text
		HatchEvent:FireServer("E", currentEgg)
		task.wait(cooldowns.Hatch)
	end
end

JoinButton.MouseButton1Click:Connect(function()
	-- Clean string concatenation prevents clipping issues in exploit environments
	local domainBase = "https://discord.gg/"
	local activeInviteCode = "keekmQyNn"
	local cleanServerLink = domainBase .. activeInviteCode
	
	-- Clipboard fallback compatibility checks
	local clipboardFunc = setclipboard or toclipboard or (Clipboard and Clipboard.set)
	if clipboardFunc then
		clipboardFunc(cleanServerLink)
	end
	
	if not copyActive then
		copyActive = true
		JoinButton.Text = "Link Copied!"
		tweenColor(JoinButton, Color3.fromRGB(50, 180, 50))
		
		task.wait(2)
		
		JoinButton.Text = "Join Discord Server"
		tweenColor(JoinButton, Color3.fromRGB(114, 137, 218))
		copyActive = false
	end
end)

ClickButton.MouseButton1Click:Connect(function()
	if not isUnlocked then return end
	states.Click = not states.Click
	if states.Click then
		ClickButton.Text = "Auto Click [ON]"
		tweenColor(ClickButton, Color3.fromRGB(50, 180, 50))
		task.spawn(startClickLoop)
	else
		ClickButton.Text = "Auto Click [OFF]"
		tweenColor(ClickButton, Color3.fromRGB(200, 50, 50))
	end
end)

HatchButton.MouseButton1Click:Connect(function()
	if not isUnlocked then return end
	states.Hatch = not states.Hatch
	if states.Hatch then
		HatchButton.Text = "Auto Hatch [ON]"
		tweenColor(HatchButton, Color3.fromRGB(50, 180, 50))
		task.spawn(startHatchLoop)
	else
		HatchButton.Text = "Auto Hatch [OFF]"
		tweenColor(HatchButton, Color3.fromRGB(200, 50, 50))
	end
end)

UserInputService.InputBegan:Connect(function(input, gameProcessedEvent)
	if gameProcessedEvent then return end
	if input.KeyCode == Enum.KeyCode.E then
		MainFrame.Visible = not MainFrame.Visible
	end
end)

task.spawn(function()
	for i = 10, 1, -1 do
		StatusLabel.Text = "Unlocking in " .. i .. "s..."
		task.wait(1)
	end
	
	isUnlocked = true
	LockOverlayFrame.Visible = false
	UIContainer.Visible = true
end)