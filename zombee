local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local CoreGui = game:GetService("CoreGui")
local UserInputService = game:GetService("UserInputService")
local LocalPlayer = Players.LocalPlayer
local GunRemote = ReplicatedStorage:WaitForChild("Gun")

local NPC_FOLDER_NAME = "NPCs" 
local autoHitActive = false 
local hitDelay = 0.15 
local maxDistance = 75 

local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Parent = CoreGui 
ScreenGui.Name = "AutoHitTracker"
ScreenGui.Enabled = false 

local MainFrame = Instance.new("Frame")
MainFrame.Size = UDim2.new(0, 250, 0, 45)
MainFrame.Position = UDim2.new(0.5, -125, 0, 15) 
MainFrame.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
MainFrame.BorderSizePixel = 0
MainFrame.Parent = ScreenGui

local UICorner = Instance.new("UICorner")
UICorner.CornerRadius = UDim.new(0, 8)
UICorner.Parent = MainFrame

local StatusLabel = Instance.new("TextLabel")
StatusLabel.Size = UDim2.new(1, 0, 1, 0)
StatusLabel.BackgroundTransparency = 1
StatusLabel.Text = "Target: [Searching...]"
StatusLabel.TextColor3 = Color3.fromRGB(230, 230, 230)
StatusLabel.Font = Enum.Font.GothamBold
StatusLabel.TextSize = 14
StatusLabel.Parent = MainFrame

local function getClosestNPC()
    local closestTarget = nil
    local shortestDistance = maxDistance
    
    local character = LocalPlayer.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then 
        return nil 
    end
    
    local myPos = character.HumanoidRootPart.Position
    local npcFolder = workspace:FindFirstChild(NPC_FOLDER_NAME)
    local scanTargets = npcFolder and npcFolder:GetChildren() or workspace:GetChildren()
    
    for _, obj in ipairs(scanTargets) do
        if obj:IsA("Model") and obj ~= character and obj:FindFirstChild("Humanoid") and obj:FindFirstChild("HumanoidRootPart") then
            if not Players:GetPlayerFromCharacter(obj) and not obj:FindFirstChild("PlayerGui") then
                if obj.Humanoid.Health > 0 then
                    local distance = (obj.HumanoidRootPart.Position - myPos).Magnitude
                    if distance < shortestDistance then
                        shortestDistance = distance
                        closestTarget = obj
                    end
                end
            end
        end
    end
    return closestTarget
end

local function getEquippedWeaponName()
    local character = LocalPlayer.Character
    if character then
        local tool = character:FindFirstChildOfClass("Tool")
        if tool then
            return tool.Name
        end
    end
    return "Pistol" 
end

UserInputService.InputBegan:Connect(function(input, gameProcessedEvent)
    if gameProcessedEvent then return end
    if input.KeyCode == Enum.KeyCode.Q then
        autoHitActive = not autoHitActive
        ScreenGui.Enabled = autoHitActive 
    end
end)

task.spawn(function()
    while true do
        task.wait(hitDelay)
        
        if autoHitActive then
            local target = getClosestNPC()
            
            if target then
                local weaponName = getEquippedWeaponName()
                local myCharacter = LocalPlayer.Character
                
                if myCharacter and myCharacter:FindFirstChild("HumanoidRootPart") then
                    StatusLabel.Text = "Target: " .. target.Name
                    StatusLabel.TextColor3 = Color3.fromRGB(85, 255, 127)
                    
                    local originPos = myCharacter.HumanoidRootPart.Position
                    local targetPart = target:FindFirstChild("HumanoidRootPart") or target:FindFirstChild("Head")
                    local targetPos = targetPart.Position
                    local directionVec = (targetPos - originPos).Unit
                    
                    local ohTable1 = {
                        ["Normal"] = { -0.81055, 0.40613, -0.42195 }, 
                        ["Direction"] = { directionVec.X * 100, directionVec.Y * 100, directionVec.Z * 100 },
                        ["Name"] = weaponName,
                        ["Hit"] = targetPart,
                        ["Origin"] = { originPos.X, originPos.Y, originPos.Z },
                        ["Pos"] = { targetPos.X, targetPos.Y, targetPos.Z }
                    }
                    
                    GunRemote:FireServer(ohTable1)
                end
            else
                StatusLabel.Text = "Target: [Searching...]"
                StatusLabel.TextColor3 = Color3.fromRGB(230, 230, 230)
            end
        end
    end
end)