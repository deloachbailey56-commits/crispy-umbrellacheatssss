local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local CoreGui = game:GetService("CoreGui")
local UserInputService = game:GetService("UserInputService")
local LocalPlayer = Players.LocalPlayer
local GunRemote = ReplicatedStorage:WaitForChild("Gun")

local autoFarmActive = false 
local hitDelay = 0.05 
local farmDistance = 60 
local attacksPerLoop = 2 

local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Parent = CoreGui 
ScreenGui.Name = "AutoFarmTracker"
ScreenGui.Enabled = false 

local MainFrame = Instance.new("Frame")
MainFrame.Size = UDim2.new(0, 250, 0, 45)
MainFrame.Position = UDim2.new(0.5, -125, 0, 15) 
MainFrame.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
MainFrame.BorderSizePixel = 0
MainFrame.Parent = ScreenGui

local UICorner = Instance.new("UICorner")
UICorner.CornerRadius = UDim.new(0, 8)
UICorner.Parent = MainFrame

local StatusLabel = Instance.new("TextLabel")
StatusLabel.Size = UDim2.new(1, 0, 1, 0)
StatusLabel.BackgroundTransparency = 1
StatusLabel.Text = "AUTOFARM: OFF"
StatusLabel.TextColor3 = Color3.fromRGB(255, 85, 85)
StatusLabel.Font = Enum.Font.GothamBold
StatusLabel.TextSize = 14
StatusLabel.Parent = MainFrame

local currentTarget = nil

local function updateTarget()
    local character = LocalPlayer.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then 
        currentTarget = nil
        return 
    end
    
    local myPos = character.HumanoidRootPart.Position
    local nearestTarget = nil
    local shortestDistance = farmDistance
    local enemiesFolder = workspace:FindFirstChild("enemies")
    
    if enemiesFolder then
        for _, obj in ipairs(enemiesFolder:GetChildren()) do
            if obj:IsA("Model") then
                local humanoid = obj:FindFirstChildOfClass("Humanoid")
                local root = obj:FindFirstChild("HumanoidRootPart")
                
                if humanoid and root and humanoid.Health > 0 then
                    local distance = (root.Position - myPos).Magnitude
                    if distance < shortestDistance then
                        shortestDistance = distance
                        nearestTarget = obj
                    end
                end
            end
        end
    end
    
    currentTarget = nearestTarget
end

local function getEquippedWeaponName()
    local character = LocalPlayer.Character
    if character then
        local tool = character:FindFirstChildOfClass("Tool")
        if tool then
            return tool.Name
        end
    end
    return "Pistol" 
end

UserInputService.InputBegan:Connect(function(input, gameProcessedEvent)
    if gameProcessedEvent then return end
    if input.KeyCode == Enum.KeyCode.Q then
        autoFarmActive = not autoFarmActive
        ScreenGui.Enabled = autoFarmActive 
        
        if autoFarmActive then
            StatusLabel.Text = "AUTOFARM: ACTIVE"
            StatusLabel.TextColor3 = Color3.fromRGB(85, 255, 127)
        else
            StatusLabel.Text = "AUTOFARM: OFF"
            StatusLabel.TextColor3 = Color3.fromRGB(255, 85, 85)
            currentTarget = nil
        end
    end
end)

task.spawn(function()
    while true do
        task.wait() 
        if autoFarmActive then
            updateTarget()
        end
    end
end)

task.spawn(function()
    while true do
        task.wait(hitDelay)
        
        if autoFarmActive and currentTarget then
            local myCharacter = LocalPlayer.Character
            if myCharacter and myCharacter:FindFirstChild("HumanoidRootPart") then
                local myRoot = myCharacter.HumanoidRootPart
                local targetRoot = currentTarget:FindFirstChild("HumanoidRootPart") or currentTarget:FindFirstChild("Head")
                
                if targetRoot and currentTarget:FindFirstChild("Humanoid") and currentTarget.Humanoid.Health > 0 then
                    local weaponName = getEquippedWeaponName()
                    local originPos = myRoot.Position
                    local targetPos = targetRoot.Position
                    local directionVec = (targetPos - originPos).Unit
                    
                    local ohTable1 = {
                        ["Normal"] = { -0.81055, 0.40613, -0.42195 }, 
                        ["Direction"] = { directionVec.X * farmDistance, directionVec.Y * farmDistance, directionVec.Z * farmDistance },
                        ["Name"] = weaponName,
                        ["Hit"] = targetRoot,
                        ["Origin"] = { originPos.X, originPos.Y, originPos.Z },
                        ["Pos"] = { targetPos.X, targetPos.Y, targetPos.Z }
                    }
                    
                    StatusLabel.Text = "KILLING: " .. currentTarget.Name
                    StatusLabel.TextColor3 = Color3.fromRGB(85, 255, 127)
                    
                    for i = 1, attacksPerLoop do
                        GunRemote:FireServer(ohTable1)
                    end
                end
            end
        elseif autoFarmActive and not currentTarget then
            StatusLabel.Text = "AUTOFARM: SEARCHING..."
            StatusLabel.TextColor3 = Color3.fromRGB(230, 230, 230)
        end
    end
end)