local objectsFolder = game:GetService("Workspace").CartRideWorkspace.Objects
local levelUpRemote = game:GetService("ReplicatedStorage").Events.LevelUp

local function findLastLevelModel()
    local highestLevel = 0
    local targetModel = nil

    for _, model in pairs(objectsFolder:GetChildren()) do
        if model:IsA("Model") and model.Name == "LevelSpawn" then
            for _, descendant in pairs(model:GetDescendants()) do
                if descendant:IsA("TextLabel") or descendant:IsA("TextBox") then
                    local levelNum = tonumber(string.match(descendant.Text, "%d+"))
                    if levelNum and levelNum > highestLevel then
                        highestLevel = levelNum
                        targetModel = model
                    end
                end
            end
        end
    end
    return targetModel, highestLevel
end

WinButton.MouseButton1Click:Connect(function()
    StatusLabel.Text = "Scanning levels..."
    StatusLabel.TextColor3 = Color3.fromRGB(240, 200, 50)
    
    local finalModel, finalLevelNum = findLastLevelModel()
    
    if finalModel then
        levelUpRemote:FireServer(finalModel)
        StatusLabel.Text = "Fired Stage: " .. tostring(finalLevelNum)
        StatusLabel.TextColor3 = Color3.fromRGB(50, 220, 100)
    else
        StatusLabel.Text = "Scan Error!"
        StatusLabel.TextColor3 = Color3.fromRGB(240, 50, 50)
    end
    
    task.delay(3, function()
        StatusLabel.Text = "Cart Ride Farm"
        StatusLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
    end)
end)