local function getRawCoordinates(instance)
    if not instance then return 0, 0, 0 end
    local position = instance.Position
    if type(position) == "table" then
        return position[1] or position.X or 0, position[2] or position.Y or 0, position[3] or position.Z or 0
    elseif typeof(position) == "Vector3" then
        return position.X, position.Y, position.Z
    end
    return 0, 0, 0
end

local function isZombieActive(zombie)
    if not zombie or not zombie.Parent then return false end
    
    local humanoid = zombie:FindFirstChildOfClass("Humanoid")
    local root = zombie:FindFirstChild("HumanoidRootPart")
    
    if humanoid and root and humanoid.Health > 0 then
        if humanoid.Jump then
            return true
        end
        local velocity = root.AssemblyLinearVelocity
        if typeof(velocity) == "Vector3" and velocity.Magnitude > 0.1 then
            return true
        elseif type(velocity) == "table" then
            local vx = velocity[1] or velocity.X or 0
            local vy = velocity[2] or velocity.Y or 0
            local vz = velocity[3] or velocity.Z or 0
            if math.sqrt(vx^2 + vy^2 + vz^2) > 0.1 then
                return true
            end
        end
    end
    return false
end

local function getTopFiveTargets()
    local character = LocalPlayer.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then 
        return {} 
    end
    
    local myX, myY, myZ = getRawCoordinates(character.HumanoidRootPart)
    local validEnemies = {}
    local enemiesFolder = workspace:FindFirstChild("enemies")
    
    if enemiesFolder then
        for _, obj in ipairs(enemiesFolder:GetChildren()) do
            if obj:IsA("Model") and isZombieActive(obj) then
                local root = obj:FindFirstChild("HumanoidRootPart")
                if root then
                    local zX, zY, zZ = getRawCoordinates(root)
                    local distance = math.sqrt((zX - myX)^2 + (zY - myY)^2 + (zZ - myZ)^2)
                    
                    if distance < farmDistance then
                        table.insert(validEnemies, {instance = obj, dist = distance})
                    end
                end
            end
        end
    end
    
    table.sort(validEnemies, function(a, b)
        return a.dist < b.dist
    end)
    
    local targets = {}
    for i = 1, math.min(5, #validEnemies) do
        table.insert(targets, validEnemies[i].instance)
    end
    
    return targets
end

local function getEquippedWeaponName()
    local character = LocalPlayer.Character
    if character then
        local tool = character:FindFirstChildOfClass("Tool")
        if tool then
            return tool.Name
        end
    end
    return "Pistol" 
end

UserInputService.InputBegan:Connect(function(input, gameProcessedEvent)
    if gameProcessedEvent then return end
    if input.KeyCode == Enum.KeyCode.Q then
        autoFarmActive = not autoFarmActive
        ScreenGui.Enabled = autoFarmActive 
        
        if autoFarmActive then
            StatusLabel.Text = "MULTI-FARM: ACTIVE"
            StatusLabel.TextColor3 = Color3.fromRGB(85, 255, 127)
        else
            StatusLabel.Text = "MULTI-FARM: OFF"
            StatusLabel.TextColor3 = Color3.fromRGB(255, 85, 85)
        end
    end
end)

task.spawn(function()
    while true do
        task.wait(hitDelay)
        
        if autoFarmActive then
            local targets = getTopFiveTargets()
            local myCharacter = LocalPlayer.Character
            
            if #targets > 0 and myCharacter and myCharacter:FindFirstChild("HumanoidRootPart") then
                local myRoot = myCharacter.HumanoidRootPart
                local weaponName = getEquippedWeaponName()
                local myX, myY, myZ = getRawCoordinates(myRoot)
                
                StatusLabel.Text = "ATTACKING: " .. #targets .. " TARGETS"
                StatusLabel.TextColor3 = Color3.fromRGB(85, 255, 127)
                
                for _, target in ipairs(targets) do
                    local targetRoot = target:FindFirstChild("HumanoidRootPart") or target:FindFirstChild("Head")
                    if targetRoot then
                        local tX, tY, tZ = getRawCoordinates(targetRoot)
                        
                        local diffX = tX - myX
                        local diffY = tY - myY
                        local diffZ = tZ - myZ
                        local length = math.sqrt(diffX^2 + diffY^2 + diffZ^2)
                        
                        local dirX, dirY, dirZ = 0, 0, 0
                        if length > 0 then
                            dirX = diffX / length
                            dirY = diffY / length
                            dirZ = diffZ / length
                        end
                        
                        local ohTable1 = {
                            ["Normal"] = { -0.81055, 0.40613, -0.42195 }, 
                            ["Direction"] = { dirX * farmDistance, dirY * farmDistance, dirZ * farmDistance },
                            ["Name"] = weaponName,
                            ["Hit"] = targetRoot,
                            ["Origin"] = { myX, myY, myZ },
                            ["Pos"] = { tX, tY, tZ }
                        }
                        
                        for i = 1, attacksPerTarget do
                            GunRemote:FireServer(ohTable1)
                        end
                    end
                end
            else
                if autoFarmActive then
                    StatusLabel.Text = "MULTI-FARM: SEARCHING..."
                    StatusLabel.TextColor3 = Color3.fromRGB(230, 230, 230)
                end
            end
        end
    end
end)